# Google Cloud
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
# Use a region that supports your model (2.5 Pro: asia-northeast1 or us-central1, not asia-south1)
VERTEX_AI_LOCATION=asia-northeast1
GEMINI_MODEL=gemini-2.5-pro
GEMINI_FAST_MODEL=gemini-2.5-flash
# Rate limits — see docs/RATE_LIMITS.md
VERTEX_MAX_CONCURRENT=1
VERTEX_MIN_INTERVAL_MS=3000
GEMINI_CLAUSE_CONCURRENCY=1
GEMINI_CLAUSE_GAP_MS=2000
GEMINI_MAX_RETRIES=6
GEMINI_JSON_PARSE_RETRIES=1
LEXGUARD_RAG_MODE=category-first
LEXGUARD_RUNTIME_EMBEDDINGS=local
GEMINI_ORCHESTRATOR_TIER=fast
# Cross-clause AI (set false in production to save 1 Gemini call; heuristics always run)
LEXGUARD_CROSS_CLAUSE_AI=false
# LLM clause extraction when heuristics find <55% of sections (adds 0-1 Gemini call)
LEXGUARD_LLM_EXTRACT=auto
# Public app URL (shown in UI banner)
VITE_PUBLIC_APP_URL=https://lexguard-api-319474876307.asia-northeast1.run.app

# Document AI
DOCUMENT_AI_PROCESSOR_ID=your-processor-id
DOCUMENT_AI_LOCATION=asia-southeast1

# Vector Search (optional — falls back to local corpus + embeddings)
VECTOR_SEARCH_LOCATION=us-central1
VECTOR_SEARCH_INDEX_ENDPOINT=
VECTOR_SEARCH_DEPLOYED_INDEX_ID=
VECTOR_SEARCH_INDEX_ID=
VECTOR_SEARCH_METRIC=cosine

# Embeddings (must match your Vector Search index dimensions)
EMBEDDING_MODEL=text-embedding-004
EMBEDDING_DIMENSIONS=256
RAG_TOP_K=3

# Image OCR: gemini-vision (default) or documentai
LEXGUARD_IMAGE_OCR=gemini-vision
# Scanned PDF OCR: gemini-vision (default) or documentai
LEXGUARD_PDF_OCR=gemini-vision

# URL import — jina reader when sites block bots
URL_READER_FALLBACK=true
URL_READER_BASE=https://r.jina.ai/
URL_FETCH_TIMEOUT_MS=30000

# GCS + Firestore
GCS_BUCKET=lexguard-documents
FIRESTORE_COLLECTION=sessions

# Google OAuth (export features)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3050/api/auth/callback
APP_ORIGIN=http://localhost:5173

# Server
PORT=3050
NODE_ENV=development
# Comma-separated origins for production CORS (leave unset in dev — Vite proxy handles /api)
# CORS_ORIGIN=https://your-app.web.app,https://your-cloud-run-url.run.app
VITE_API_URL=http://localhost:3050

# Demo mode — keyword/mock agents only; keep false for real Vertex analysis
LEXGUARD_DEMO_MODE=false
# LEXGUARD_MEMORY_STORE=true   # CI/tests — skip Firestore/GCS
